:rules_000 a void:Dataset.
:source_000 a rml:LogicalSource;
    rdfs:label "root";
    rml:source ".rml_work/current.json";
    rml:iterator "$";
    rml:referenceFormulation ql:JSONPath.
:source_001 a rml:LogicalSource;
    rdfs:label "creators";
    rml:source ".rml_work/current.json";
    rml:iterator "$._creators[*]";
    rml:referenceFormulation ql:JSONPath.
:source_002 a rml:LogicalSource;
    rdfs:label "contributors";
    rml:source ".rml_work/current.json";
    rml:iterator "$._contributors[*]";
    rml:referenceFormulation ql:JSONPath.
:source_003 a rml:LogicalSource;
    rdfs:label "shared_with";
    rml:source ".rml_work/current.json";
    rml:iterator "$.shared_with[*]";
    rml:referenceFormulation ql:JSONPath.
:source_004 a rml:LogicalSource;
    rdfs:label "rights_holder";
    rml:source ".rml_work/current.json";
    rml:iterator "$.rights_holder[*]";
    rml:referenceFormulation ql:JSONPath.
:source_005 a rml:LogicalSource;
    rdfs:label "relation";
    rml:source ".rml_work/current.json";
    rml:iterator "$.relation[*]";
    rml:referenceFormulation ql:JSONPath.
:source_006 a rml:LogicalSource;
    rdfs:label "keywords";
    rml:source ".rml_work/current.json";
    rml:iterator "$.keywords[*]";
    rml:referenceFormulation ql:JSONPath.
